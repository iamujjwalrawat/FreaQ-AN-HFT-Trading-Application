# FreaQ Environment Variables
# Copy to .env.local for development

# NextAuth (REQUIRED)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=freaq-change-this-to-random-secret-in-production

# GitHub OAuth (optional - sign in with GitHub)
# Create at: https://github.com/settings/developers
GITHUB_ID=your_github_oauth_app_id
GITHUB_SECRET=your_github_oauth_app_secret

# Google OAuth (optional - sign in with Google)
# Create at: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Finnhub API - Real-time free stock data (recommended)
# Get free API key at: https://finnhub.io/register
# Free tier: 60 requests/minute, WebSocket access
FINNHUB_API_KEY=your_finnhub_api_key

# Alpha Vantage - Backup stock data (optional)
# Get free key at: https://www.alphavantage.co/support/#api-key
# Free tier: 25 requests/day
ALPHA_VANTAGE_KEY=your_alpha_vantage_key

# Polygon.io - Additional market data (optional)
# Get free key at: https://polygon.io/dashboard/signup
POLYGON_API_KEY=your_polygon_api_key

# OpenAI - Powers AI market assistant (optional)
# Get key at: https://platform.openai.com/api-keys
# Without this key, FreaQ AI uses smart built-in responses
OPENAI_API_KEY=your_openai_api_key

# Notes:
# - Yahoo Finance and CoinGecko APIs work WITHOUT any API key
# - Demo mode works completely without any API keys
# - For production, set NEXTAUTH_URL to your Vercel deployment URL
